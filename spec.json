    "notion-search": {
      "description": "Manage notion search",
      "endpoints": {
        "search": {
          "method": "POST",
          "path": "/v1/search",
          "description": "Search for pages, databases, and other objects within a Notion workspace.",
          "params": [],
          "body": [
            {
              "name": "filter",
              "type": "object",
              "required": false,
              "positional": false,
              "default": null,
              "description": "Filter",
              "fields": [
                {
                  "name": "property",
                  "type": "string",
                  "required": true,
                  "positional": false,
                  "default": null,
                  "description": "Property",
                  "fields": null
                },
                {
                  "name": "value",
                  "type": "string",
                  "required": true,
                  "positional": false,
                  "default": null,
                  "description": "The type of object to filter by (e.g., `page`, `database`).",
                  "fields": null
                }
              ]
            },
            {
              "name": "page_size",
              "type": "int",
              "required": false,
              "positional": false,
              "default": null,
              "description": "Number of results to return per page.",
              "fields": null
            },
            {
              "name": "query",
              "type": "string",
              "required": false,
              "positional": false,
              "default": null,
              "description": "The text to search for.",
              "fields": null
            },
            {
              "name": "sort",
              "type": "object",
              "required": false,
              "positional": false,
              "default": null,
              "description": "Sort",
              "fields": [
                {
                  "name": "direction",
                  "type": "string",
                  "required": false,
                  "positional": false,
                  "default": null,
                  "description": "Direction",
                  "fields": null,
                  "enum": [
                    "ascending",
                    "descending"
                  ]
                },
                {
                  "name": "timestamp",
                  "type": "string",
                  "required": false,
                  "positional": false,
                  "default": null,
                  "description": "Timestamp",
                  "fields": null,
                  "enum": [
                    "last_edited_time"
                  ]
                }
              ]
            },
            {
              "name": "start_cursor",
              "type": "string",
              "required": false,
              "positional": false,
              "default": null,
              "description": "Pagination cursor for the start of the search results.",
              "fields": null
