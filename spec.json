            {
              "name": "start_cursor",
              "type": "string",
              "required": false,
              "positional": false,
              "default": null,
              "description": "Pagination cursor for fetching the next set of results.",
              "fields": null
            },
            {
              "name": "page_size",
              "type": "int",
              "required": false,
              "positional": false,
              "default": null,
              "description": "The number of results to retrieve per page (default is 100).",
              "fields": null
            }
          ],
          "body": [],
          "response": {
            "type": "object",
            "item": "BlockChildrenResponse"
          },
          "tags": [
            "Blocks"
          ],
          "pagination": {
            "type": "cursor",
            "limit_param": "page_size",
            "cursor_param": "",
            "next_cursor_path": "",
            "has_more_field": "has_more"
          }
        },
        "update-block": {
          "method": "PATCH",
          "path": "/v1/blocks/{block_id}/children",
          "description": "Update the children of a block.",
          "params": [
            {
              "name": "block_id",
              "type": "string",
              "required": true,
              "positional": true,
              "path_param": true,
              "default": null,
              "description": "The ID of the block to update.",
              "fields": null
            }
          ],
          "body": [
            {
              "name": "children",
              "type": "array",
              "required": true,
              "positional": false,
              "default": null,
              "description": "The list of block children to update.",
              "fields": null
