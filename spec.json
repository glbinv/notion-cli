{
  "name": "notion",
  "description": "Combined CLI for multiple API services",
  "version": "1.0.0",
  "base_url": "https://api.notion.com",
  "owner": "user",
  "owner_name": "user",
  "spec_source": "community",
  "category": "productivity",
  "auth": {
    "type": "bearer_token",
    "header": "Authorization",
    "format": "",
    "env_vars": [
      "NOTION_BEARER_AUTH"
    ],
    "env_var_specs": [
      {
        "name": "NOTION_BEARER_AUTH",
        "kind": "per_call",
        "required": true,
        "sensitive": true,
        "inferred": true
      }
    ],
    "scheme": "bearerAuth"
  },
  "config": {
    "format": "toml",
    "path": "~/.config/notion-pp-cli/config.toml"
  },
  "resources": {
    "blocks": {
      "description": "Manage blocks",
      "endpoints": {
        "delete": {
          "method": "DELETE",
          "path": "/v1/blocks/{block_id}",
          "description": "Delete a block using its ID.",
          "params": [
            {
              "name": "block_id",
              "type": "string",
              "required": true,
              "positional": true,
              "path_param": true,
              "default": null,
              "description": "The ID of the block to delete.",
              "fields": null
            }
          ],
          "body": [],
          "response": {
            "type": "object",
            "item": "BlockResponse"
          },
          "tags": [
            "Blocks"
          ],
          "pagination": null,
          "id_field": "id"
        },
        "retrieve": {
          "method": "GET",
          "path": "/v1/blocks/{block_id}",
          "description": "Retrieve a block object using its ID.",
          "params": [
            {
              "name": "block_id",
              "type": "string",
              "required": true,
              "positional": true,
              "path_param": true,
              "default": null,
              "description": "The ID of the block to retrieve.",
              "fields": null
            }
          ],
          "body": [],
          "response": {
            "type": "object",
            "item": "BlockResponse"
          },
          "tags": [
            "Blocks"
          ],
          "pagination": null,
          "id_field": "id"
        },
        "update": {
          "method": "PATCH",
          "path": "/v1/blocks/{block_id}",
          "description": "Update a block's properties.",
          "params": [
            {
              "name": "block_id",
              "type": "string",
              "required": true,
              "positional": true,
              "path_param": true,
              "default": null,
              "description": "The ID of the block to update.",
              "fields": null
            }
          ],
          "body": [
            {
              "name": "properties",
              "type": "object",
              "required": false,
              "positional": false,
              "default": null,
              "description": "The properties to update for the block.",
              "fields": null
            },
            {
              "name": "type",
              "type": "string",
              "required": true,
              "positional": false,
              "default": null,
              "description": "The type of block (e.g., paragraph, image).",
              "fields": null
            }
          ],
          "body_required": true,
          "request_content_type": "application/json",
          "response": {
            "type": "object",
            "item": "BlockResponse"
          },
          "tags": [
            "Blocks"
          ],
          "pagination": null,
          "id_field": "id"
        }
      }
    },
    "children": {
      "description": "Manage children",
      "endpoints": {
        "retrieve-block": {
          "method": "GET",
          "path": "/v1/blocks/{block_id}/children",
